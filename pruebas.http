### ========================================================
### 1. CREAR EL PERFIL DE JUAN (EL QUE VA A SER CHOCADO)
### ========================================================
POST http://localhost:3000/api/perfil
Content-Type: application/json

{
  "nombre": "Juan Pérez",
  "dni": "35123456",
  "domicilio": "Av. Corrientes 1234, CABA",
  "telefono": "+54 11 9999-8888",
  "licencia": "LIC-ABC-123",
  "patente": "AA123BB",
  "marca": "Volkswagen",
  "modelo": "Gol Trend",
  "anio": 2018,
  "motor": "MOT-9999",
  "chasis": "CHA-8888",
  "aseguradora": "La Caja Seguros",
  "poliza": "POL-999-888",
  "vencimiento": "2027-12-31"
}

